---
import { Image } from 'astro:assets';

interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
  description?: string;
  image: ImageMetadata;
  height?: 'small' | 'large';
  align?: 'left' | 'center';
}

const { 
  badge, 
  title, 
  subtitle, 
  description, 
  image,
  height = 'large',
  align = 'left'
} = Astro.props;

// Conditional classes
const heightClass = height === 'large' ? 'min-h-[80vh] md:min-h-[90vh]' : 'min-h-[50vh] md:min-h-[60vh]';
const alignClass = align === 'center' ? 'items-center text-center' : 'items-start text-left';
---

<div class={`relative flex ${alignClass} ${heightClass} w-full overflow-hidden bg-dark`}>
  {/* Background Image with Overlay */}
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-gradient-to-r from-dark/90 via-dark/80 to-transparent z-10"></div>
    {/* Optional vertical gradient for better blending */}
    <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-dark to-transparent z-10"></div>
    {image && (
      <Image 
        src={image} 
        alt="Hero background" 
        class="w-full h-full object-cover object-center opacity-60"
        loading="eager"
      />
    )}
  </div>

  {/* Content */}
  <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-20">
    <div class={`max-w-3xl ${align === 'center' ? 'mx-auto' : ''}`}>
      {badge && (
        <span class="inline-block py-1 px-3 md:px-4 rounded-full bg-primary/20 border border-primary text-red-100 text-base font-semibold tracking-wider mb-6 animate-fade-in-up">
          {badge}
        </span>
      )}
      
      <h1 class="text-4xl md:text-5xl lg:text-7xl font-extrabold text-white tracking-tight leading-tight mb-4 animate-fade-in-up" style="animation-delay: 100ms;">
        {title}
      </h1>
      
      {subtitle && (
        <h2 class={`text-xl md:text-3xl text-gray-200 font-medium mb-6 animate-fade-in-up ${align === 'center' ? 'mx-auto' : ''}`} style="animation-delay: 200ms;">
          {subtitle}
        </h2>
      )}
      
      {description && (
        <p class={`text-lg md:text-xl text-gray-300 mb-8 max-w-2xl leading-relaxed animate-fade-in-up ${align === 'center' ? 'mx-auto' : ''}`} style="animation-delay: 300ms;">
          {description}
        </p>
      )}

      <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up" style="animation-delay: 400ms;">
        <slot name="actions" />
      </div>
    </div>
  </div>
</div>

<style>
  /* Base animation keyframes for internal micro-animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0; /* Starts hidden until animation */
  }
</style>
