---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/ui/Header.astro';
import Footer from '../components/ui/Footer.astro';
import Hero from '../components/ui/Hero.astro';
import FeatureCard from '../components/ui/FeatureCard.astro';
import { empresasData } from '../data/empresasData';
import heroImage from '../assets/imagenes/banner-servicios-empresas.webp';

// Dynamic import of images for services and subpages
const images = import.meta.glob<{ default: ImageMetadata }>('../assets/imagenes/*.webp', { eager: true });

const { hero, services, subPages } = empresasData;
---

<BaseLayout title={hero.title} description={hero.description}>
  <Header slot="header" />
  
  <main>
    {/* Page Hero */}
    <Hero 
      badge="Unidad 1"
      title={hero.title}
      subtitle={hero.subtitle}
      description={hero.description}
      image={heroImage}
      height="small"
      align="center"
    />

    {/* Section: Áreas de Práctica / Services */}
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-dark mb-4">Servicios para Empleadores</h2>
          <div class="w-16 h-1 bg-primary mx-auto mb-6 rounded-full"></div>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">
            Soluciones integrales diseñadas para proteger su empresa y optimizar la gestión de su talento humano.
          </p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6 text-center">
          {services.map((service, index) => (
            <div class="bg-gray-50 rounded-xl p-6 border border-gray-100 hover:border-primary/30 hover:shadow-md transition-all group animate-fade-in-up" style={`animation-delay: ${index * 100}ms`}>
              <div class="w-12 h-12 mx-auto bg-white rounded-full flex items-center justify-center text-primary shadow-sm mb-4 group-hover:scale-110 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <h3 class="font-semibold text-dark text-sm leading-tight">{service.title}</h3>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Section: Subpáginas / Soluciones Específicas */}
    <section class="py-24 bg-light relative border-t border-gray-200 overflow-hidden">
      {/* Background decoration */}
      <div class="absolute inset-y-0 right-0 w-1/2 bg-red-50 rounded-l-[100px] opacity-50 pointer-events-none"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-dark mb-4">Soluciones Específicas</h2>
          <p class="text-lg text-gray-600 max-w-2xl">
            Profundizamos en las áreas clave para el desarrollo y protección de su organización.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {services.map((service, index) => {
            const imagePath = `../assets/imagenes/${service.image}.webp`;
            const imageMetadata = images[imagePath]?.default;
            return (
              <div class="animate-fade-in-up" style={`animation-delay: ${index * 150}ms`}>
                <FeatureCard 
                  title={service.title}
                  description={service.description}
                  icon={service.icon}
                  image={imageMetadata?.src}
                />
              </div>
            );
          })}
        </div>
      </div>
    </section>

    {/* CTA Final */}
    <section class="py-20 bg-dark text-white text-center relative overflow-hidden">
      <div class="absolute inset-0 bg-primary opacity-90 mix-blend-multiply"></div>
      <div class="relative z-10 max-w-3xl mx-auto px-4">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">¿Preparado para optimizar su empresa?</h2>
        <p class="text-xl mb-10 text-red-100">Contáctenos para una evaluación inicial y descubra cómo podemos ayudarle a mitigar riesgos.</p>
        <a href="/contacto" class="inline-flex items-center px-8 py-3 rounded-md bg-white text-primary font-bold hover:bg-gray-100 transition-colors shadow-lg">
          Agendar Asesoría
        </a>
      </div>
    </section>
  </main>
  
  <Footer slot="footer" />
</BaseLayout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
</style>
