---
import '../styles/global.css';
import { siteConfig } from '../data/siteConfig';
import { Image } from 'astro:assets';

// Assets
import profileImg from '../assets/imagenes/claudia-nunez-directora.webp';
import logoImg from '../assets/imagenes/logo-jc-negro.webp';

const pageTitle = "Tarjeta Digital de Presentación";
const pageDescription = "Tarjeta digital de contacto - JC Consultorías y Servicios";
const whatsappMessage = "Hola, me gustaría solicitar información sobre sus servicios.";
const cleanPhone = siteConfig.whatsapp.replace(/\D/g, '');
const cleanPhoneCall = siteConfig.phone.replace(/[^0-9+]/g, '');
const whatsappUrl = `https://wa.me/${cleanPhone}?text=${encodeURIComponent(whatsappMessage)}`;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- SEO -->
    <title>{pageTitle} | {siteConfig.name}</title>
    <meta name="description" content={pageDescription} />
    
    <!-- Open Graph -->
    <meta property="og:type" content="profile" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />

    <!-- Fonts: Inter & Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;700;800&display=swap" rel="stylesheet">
    
    <style>
        body { background-color: #f3f4f6; } /* Tailwind gray-100 fallback */
        .card-pattern {
            background-color: #b00d11;
            background-image: radial-gradient(#d41217 1px, transparent 1px);
            background-size: 20px 20px;
        }
    </style>
</head>
<body class="min-h-screen bg-gray-100 flex items-center justify-center p-4 antialiased selection:bg-primary/20">

  <div class="w-full max-w-sm bg-white rounded-[2rem] shadow-2xl overflow-hidden relative border border-gray-100">
    
    {/* Cover / Portada */}
    <div class="h-40 card-pattern relative flex justify-center items-center overflow-hidden">
        {/* Decorative elements behind profile */}
        <div class="absolute inset-0 opacity-20 bg-gradient-to-t from-black/50 to-transparent"></div>
        <svg viewBox="0 0 100 100" class="w-64 h-64 text-white opacity-10 absolute -right-10 -top-10 rotate-12">
            <path d="M50 0 L100 25 L100 75 L50 100 L0 75 L0 25 Z" fill="currentColor"/>
        </svg>
    </div>
    
    {/* Profile Pic */}
    <div class="flex justify-center -mt-20 relative z-10">
      <div class="relative">
          <Image 
            src={profileImg} 
            alt={siteConfig.lawyer} 
            class="w-36 h-36 rounded-full border-4 border-white object-cover shadow-lg relative z-10" 
          />
          {/* Status dot */}
          <div class="absolute bottom-2 right-2 w-6 h-6 bg-green-500 border-4 border-white rounded-full z-20"></div>
      </div>
    </div>
    
    {/* Content */}
    <div class="px-6 pt-5 pb-8 text-center">
      <h1 class="text-2xl font-bold text-dark font-outfit leading-tight mb-1">{siteConfig.lawyer.split(' - ')[0]}</h1>
      <p class="text-primary font-semibold text-xs tracking-wider uppercase mb-5 px-3 py-1 bg-red-50 rounded-full inline-block">
        Directora | {siteConfig.name}
      </p>

      {/* NUEVO - Botones de Acción Rápida */}
      <div class="flex justify-center items-center gap-2 mb-6">
        <a href={whatsappUrl} class="w-11 h-11 bg-[#25D366] text-white rounded-full flex items-center justify-center shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all" aria-label="WhatsApp">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        </a>
        <a href="#servicios" class="px-5 py-2.5 bg-primary text-white text-sm font-bold rounded-full shadow-sm hover:bg-primary-hover hover:shadow-md hover:-translate-y-0.5 transition-all flex-shrink-0">
          Agendar Asesoría
        </a>
        <a href={`tel:${cleanPhoneCall}`} class="w-11 h-11 bg-red-50 text-primary border border-red-100 rounded-full flex items-center justify-center shadow-sm hover:bg-red-100 hover:shadow-md hover:-translate-y-0.5 transition-all" aria-label="Teléfono">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </a>
        <a href={`mailto:${siteConfig.email}`} class="w-11 h-11 bg-gray-100 text-gray-700 border border-gray-200 rounded-full flex items-center justify-center shadow-sm hover:bg-gray-200 hover:shadow-md hover:-translate-y-0.5 transition-all" aria-label="Correo">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </a>
      </div>
      
      {/* Sobre Nosotros */}
      <p class="text-gray-700 text-[15px] mb-5 leading-relaxed px-2">
        Conectamos a empresas y colombianos en el exterior con soluciones legales y administrativas confiables en Colombia.
      </p>
      
      <div class="flex flex-wrap justify-center gap-2 mb-6">
        <span class="px-3 py-1 bg-primary/10 border border-primary/20 text-primary rounded-full text-[11px] font-bold uppercase tracking-wider">Derecho Laboral</span>
        <span class="px-3 py-1 bg-primary/10 border border-primary/20 text-primary rounded-full text-[11px] font-bold uppercase tracking-wider">Seguridad Social</span>
        <span class="px-3 py-1 bg-primary/10 border border-primary/20 text-primary rounded-full text-[11px] font-bold uppercase tracking-wider">Derecho Civil y Comercial</span>
      </div>
      
      {/* Información Detallada de la Empresa */}
      <div id="servicios" class="text-left space-y-6 mb-8 scroll-mt-6">
        
        {/* Quiénes Somos / Propósito */}
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
          <h3 class="font-outfit font-bold text-lg text-dark mb-2 flex items-center gap-2">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
            La Firma
          </h3>
          <p class="text-gray-600 text-sm leading-relaxed mb-3">
            Somos una firma boutique de abogados con sede en Pereira, Risaralda. Nos especializamos en resolver conflictos de carácter laboral, seguridad social, civil y comercial con un enfoque humano y altamente técnico.
          </p>
          <div class="bg-gray-50 border-l-4 border-primary p-3 rounded-r-lg">
            <p class="text-sm font-medium text-gray-800 italic">"Conectamos a empresas y colombianos en el exterior con soluciones legales y administrativas confiables en Colombia, sin importar dónde se encuentren."</p>
          </div>
        </div>

        {/* JC Empresas */}
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="bg-gray-50 px-5 py-4 border-b border-gray-100">
            <h3 class="font-outfit font-bold text-lg text-dark flex items-center gap-2">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              JC Empresas
            </h3>
            <p class="text-xs text-gray-500 mt-1">Soluciones jurídicas y de gestión para empleadores colombianos.</p>
          </div>
          <div class="p-5 space-y-4">
            
            <div class="flex gap-3">
              <div class="mt-1 flex-shrink-0 w-8 h-8 rounded-full bg-red-50 flex items-center justify-center text-primary">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
              </div>
              <div>
                <h4 class="text-sm font-bold text-gray-800">Asesoría preventiva y laboral</h4>
                <p class="text-xs text-gray-600 mt-1">Diagnósticos de riesgos, planes de mejora y acompañamiento para cumplir la normativa evitando conflictos.</p>
              </div>
            </div>

            <div class="flex gap-3">
              <div class="mt-1 flex-shrink-0 w-8 h-8 rounded-full bg-red-50 flex items-center justify-center text-primary">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path></svg>
              </div>
              <div>
                <h4 class="text-sm font-bold text-gray-800">Defensa Judicial y Trámites</h4>
                <p class="text-xs text-gray-600 mt-1">Representación legal estratégica y gestión directa de obligaciones ante entidades como ARL, EPS y UGPP.</p>
              </div>
            </div>

            <div class="flex gap-3">
              <div class="mt-1 flex-shrink-0 w-8 h-8 rounded-full bg-red-50 flex items-center justify-center text-primary">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
              </div>
              <div>
                <h4 class="text-sm font-bold text-gray-800">Gestión Empresarial y Contratación</h4>
                <p class="text-xs text-gray-600 mt-1">Estructuración de contratos seguros, esquemas de remuneración y apoyo administrativo corporativo.</p>
              </div>
            </div>

          </div>
        </div>

        {/* Colombianos en el exterior */}
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="bg-gray-50 px-5 py-4 border-b border-gray-100">
            <h3 class="font-outfit font-bold text-lg text-dark flex items-center gap-2">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              Colombianos en el Exterior
            </h3>
            <p class="text-xs text-gray-500 mt-1">Actuamos como tu puente legal con Colombia.</p>
          </div>
          <div class="p-5 space-y-4">
            
            <div class="flex gap-3">
              <div class="mt-1 flex-shrink-0 w-8 h-8 rounded-full bg-red-50 flex items-center justify-center text-primary">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
              <div>
                <h4 class="text-sm font-bold text-gray-800">Pensiones y Herencias</h4>
                <p class="text-xs text-gray-600 mt-1">Gestión de pensiones (invalidez, sobrevivencia) desde el exterior. Liquidación de sucesiones y adjudicación de bienes en Colombia.</p>
              </div>
            </div>

            <div class="flex gap-3">
              <div class="mt-1 flex-shrink-0 w-8 h-8 rounded-full bg-red-50 flex items-center justify-center text-primary">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
              </div>
              <div>
                <h4 class="text-sm font-bold text-gray-800">Inversión y Bienes Raíces</h4>
                <p class="text-xs text-gray-600 mt-1">Respaldo jurídico integral, estudio de títulos y representación en todo el proceso de compraventa de inmuebles sin necesidad de viajar.</p>
              </div>
            </div>

            <div class="flex gap-3">
              <div class="mt-1 flex-shrink-0 w-8 h-8 rounded-full bg-red-50 flex items-center justify-center text-primary">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"></path></svg>
              </div>
              <div>
                <h4 class="text-sm font-bold text-gray-800">Derecho de Familia & Notariado</h4>
                <p class="text-xs text-gray-600 mt-1">Separaciones, divorcios, custodia infantil legalizada, apostillas y obtención de certificados a nivel notarial.</p>
              </div>
            </div>

          </div>
        </div>

      </div>
      
      {/* Ubicación e Info Extra */}
      <div class="space-y-3.5">
        <a href={`https://maps.google.com/?q=${encodeURIComponent(siteConfig.address)}`} target="_blank" rel="noopener noreferrer" class="group flex items-center w-full px-5 py-3.5 bg-gray-50 text-dark border border-gray-200 rounded-xl font-medium shadow-sm hover:bg-gray-100 hover:-translate-y-0.5 transition-all duration-300">
           <div class="bg-white p-2 rounded-lg shadow-sm border border-gray-100 mr-4 group-hover:scale-110 transition-transform">
               <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
           </div>
           <span class="text-left flex-1" style="font-size: 0.95rem;">Ubicación en Google Maps<br><span class="text-xs text-gray-400 font-normal">Pereira, Risaralda</span></span>
        </a>
      </div>
      
      {/* Socials Centered */}
      <div class="flex justify-center items-center space-x-5 mt-8 border-t border-gray-100 pt-6">
          <a href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-[#1877F2] hover:scale-110 transition-all" aria-label="Facebook">
              <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
          </a>
          <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-[#E1306C] hover:scale-110 transition-all" aria-label="Instagram">
              <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
      </div>
      
      {/* Footer Logo */}
      <div class="mt-8 flex flex-col items-center">
           <a href="/">
               <Image src={logoImg} alt="Logo" class="h-10 w-auto opacity-80 mb-1 grayscale hover:grayscale-0 transition-all duration-300" />
           </a>
      </div>
      
    </div>
  </div>

</body>
</html>
